  "bugs": {
    "url": "https://github.com/JN-EPHEC/individual-EkssTV/issues"
  },
  "homepage": "https://github.com/JN-EPHEC/individual-EkssTV#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
